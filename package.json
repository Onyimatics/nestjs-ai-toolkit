{
  "name": "nestjs-ai-toolkit",
  "version": "0.3.0",
  "description": "Production-ready LLM integration for NestJS. OpenAI, Anthropic, and more through one unified interface with streaming, retries, rate limiting, and cost tracking.",
  "author": "Onyinye Favour Ezike",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "ai",
    "llm",
    "openai",
    "anthropic",
    "streaming",
    "rate-limiting",
    "cost-tracking",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Onyimatics/nestjs-ai-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Onyimatics/nestjs-ai-toolkit/issues"
  },
  "homepage": "https://github.com/Onyimatics/nestjs-ai-toolkit#readme",
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "openai": ">=4.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/testing": "^11.1.27",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "openai": "^6.44.0",
    "prettier": "^3.8.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
